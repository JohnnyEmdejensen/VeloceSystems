<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type GridSplitter}">
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="IsTabStop" Value="False"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LineDark">
        <Setter Property="Background" Value="{DynamicResource LineDarkBrush}"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LineLight">
        <Setter Property="Background" Value="{DynamicResource LineLightBrush}"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="HeaderLabel">
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Foreground" Value="{DynamicResource HeaderBrush}"></Setter>
        <Setter Property="FontSize" Value="10"></Setter>
        <Setter Property="FontFamily" Value="Bahnschrift"></Setter>
        <Setter Property="Padding" Value="4 0"></Setter>
    </Style>
    <Style TargetType="{x:Type TextBox}" x:Key="Inputtextbox">
        <Setter Property="Height" Value="20"></Setter>
        <Setter Property="Margin" Value="4 0 4 0"></Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="False">
                <Setter Property="Background" Value="Transparent"></Setter>
                <Setter Property="BorderBrush" Value="Transparent"></Setter>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource BorderBrush}"></Setter>
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"></Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="{x:Type PasswordBox}" x:Key="Inputpasswordbox">
        <Setter Property="Height" Value="20"></Setter>
        <Setter Property="Margin" Value="4 0 4 0"></Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="False">
                <Setter Property="Background" Value="Transparent"></Setter>
                <Setter Property="BorderBrush" Value="Transparent"></Setter>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource BorderBrush}"></Setter>
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"></Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="{x:Type Button}" x:Key="DialogButton">
        <Setter Property="MinWidth" Value="75"></Setter>
        <Setter Property="Height" Value="23"></Setter>
        <Style.Triggers>
            <Trigger Property="IsDefault" Value="True">
                <Setter Property="Background" Value="{DynamicResource DialogButtonDefault}"></Setter>
                <Setter Property="BorderBrush" Value="{DynamicResource DialogButtonBorderDefault}"></Setter>
                <Setter Property="Foreground" Value="{DynamicResource DialogButtonTextDefault}"></Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>