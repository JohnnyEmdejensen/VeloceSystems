<Window x:Class="VeloceCRM.Client2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client2"
        mc:Ignorable="d"
        Tag="Desktop" MinHeight="800" MinWidth="1200" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Icon="/Images/masks_48.png">
    <Border Background="{DynamicResource Background}" CornerRadius="20" BorderThickness="3" BorderBrush="{DynamicResource BorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"></RowDefinition>
                <RowDefinition Height="3"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtTitle" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Grid.Column="1" Text="{DynamicResource window.desktop.title}" FontFamily="Bahnschrift" Foreground="{DynamicResource BorderBrush}" FontSize="18" VerticalAlignment="Center"></TextBlock>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Image x:Name="appMin" MouseLeftButtonDown="appMin_MouseLeftButtonDown" Source="/Images/minimize_act.png" Width="28" Cursor="Hand"></Image>
                    <Label Width="8"></Label>
                    <Image x:Name="appRes" MouseLeftButtonDown="appRes_MouseLeftButtonDown" Source="/Images/restore_act.png" Width="28" Visibility="Collapsed"></Image>
                    <Image x:Name="appMax" MouseLeftButtonDown="appMax_MouseLeftButtonDown" Source="/Images/maximize_act.png" Width="28" Cursor="Hand"></Image>
                    <Label Width="8"></Label>
                    <Image x:Name="appCls" MouseDown="appCls_MouseDown" Source="/Images/close_act.png" Width="28" Cursor="Hand"></Image>
                    <Label Width="16"></Label>
                </StackPanel>
            </Grid>
            <Label Grid.Row="1" Padding="0" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></Label>
            <Ribbon Grid.Row="2">
                
                <Ribbon.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF4397BD" Offset="0.011"/>
                        <GradientStop Color="#FFF5ECEB" Offset="1"/>
                    </LinearGradientBrush>
                </Ribbon.Background>
                <RibbonTab Header="{DynamicResource window.desktop.ribbon.tab.home}" IsSelected="True">
                    <RibbonGroup Header="{DynamicResource window.desktop.ribbon.group.creations}">
                        <RibbonMenuButton LargeImageSource="/Images/document_new_32.png" SmallImageSource="/Images/document_new_16.png" Label="{DynamicResource window.desktop.ribbon.button.createnew}">
                            <RibbonMenuItem Header="Create company" ImageSource="/Images/factory_new_16.png"></RibbonMenuItem>
                            <RibbonMenuItem Header="Create person" ImageSource="/Images/businessmen_new_16.png"></RibbonMenuItem>
                            <RibbonMenuItem Header="Create task"></RibbonMenuItem>
                            <RibbonMenuItem Header="Create phonecall"></RibbonMenuItem>
                            <RibbonMenuItem Header="Create appointment"></RibbonMenuItem>
                            <RibbonMenuItem Header="Create document"></RibbonMenuItem>
                        </RibbonMenuButton>
                        <RibbonButton LargeImageSource="/Images/factory_32.png" SmallImageSource="/Images/factory_16.png" Label="{DynamicResource window.desktop.ribbon.button.create.company}" ></RibbonButton>
                        <RibbonButton LargeImageSource="/Images/businessmen_32.png" SmallImageSource="/Images/businessmen_16.png" Label="{DynamicResource window.desktop.ribbon.button.create.person}" ></RibbonButton>
                    </RibbonGroup>
                    <RibbonGroup Header="{DynamicResource window.desktop.ribbon.group.views}">
                        <RibbonToggleButton x:Name="cmdViewDashboard" Click="cmdViewDashboard_Click" IsChecked="True" Label="{DynamicResource window.desktop.ribbon.view.button.dashboard}" LargeImageSource="/Images/gauge_32.png" SmallImageSource="/Images/gauge_16.png"></RibbonToggleButton>
                        <RibbonToggleButton x:Name="cmdViewCompanies" Click="cmdViewCompanies_Click" IsChecked="True" Label="{DynamicResource window.desktop.ribbon.view.button.companies}" LargeImageSource="/Images/factory_view_32.png" SmallImageSource="/Images/factory_16.png"></RibbonToggleButton>
                        <RibbonToggleButton x:Name="cmdViewPersons" Click="cmdViewPersons_Click" IsChecked="True" Label="{DynamicResource window.desktop.ribbon.view.button.persons}" LargeImageSource="/Images/businessmen_view_32.png" SmallImageSource="/Images/businessmen_view_16.png"></RibbonToggleButton>
                    </RibbonGroup>
                </RibbonTab>
                <RibbonTab Header="{DynamicResource window.desktop.ribbon.tab.settings}">

                </RibbonTab>
            </Ribbon>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"></ColumnDefinition>
                    <ColumnDefinition Width="4"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="1"></ColumnDefinition>
                        <ColumnDefinition Width="1"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" x:Name="grdLeft">
                        
                    </Grid>
                    <Label Grid.Column="1" Style="{DynamicResource LineDark}"></Label>
                    <Label Grid.Column="2" Style="{DynamicResource LineLight}"></Label>
                </Grid>
                <GridSplitter Grid.Column="1"></GridSplitter>
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition Height="240"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition Height="1"></RowDefinition>
                            <RowDefinition Height="1"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="4"></ColumnDefinition>
                                <ColumnDefinition Width="240"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="1"></ColumnDefinition>
                                    <ColumnDefinition Width="1"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" x:Name="grdCenter">
                                    <TabControl>
                                        <TabItem Header="Dashboard" x:Name="pageDashboard">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1"></RowDefinition>
                                                    <RowDefinition></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Label Style="{DynamicResource LineLight}"></Label>
                                                <Grid Grid.Row="1">

                                                </Grid>
                                            </Grid>
                                        </TabItem>
                                        <TabItem Header="Companies" x:Name="pageCompanies">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1"></RowDefinition>
                                                    <RowDefinition></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Label Style="{DynamicResource LineLight}"></Label>
                                                <Grid Grid.Row="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="32"></RowDefinition>
                                                        <RowDefinition Height="1"></RowDefinition>
                                                        <RowDefinition Height="1"></RowDefinition>
                                                        <RowDefinition></RowDefinition>
                                                        <RowDefinition Height="1"></RowDefinition>
                                                        <RowDefinition Height="1"></RowDefinition>
                                                        <RowDefinition Height="25"></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">

                                                    </StackPanel>
                                                    <Label Grid.Row="1" Style="{DynamicResource LineDark}"></Label>
                                                    <Label Grid.Row="2" Style="{DynamicResource LineLight}"></Label>
                                                    <DataGrid x:Name="dgCompanies" Grid.Row="3">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Visibility="Collapsed"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.number}" Binding="{Binding Number}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.name}" Binding="{Binding Name}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.address}" Binding="{Binding Address}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.zipcode}" Binding="{Binding Zipcode}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.city}" Binding="{Binding City}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.country}" Binding="{Binding Country}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.phone}" Binding="{Binding Phone}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.email}" Binding="{Binding Email}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.website}" Binding="{Binding Website}"></DataGridTextColumn>
                                                            <DataGridTextColumn Header="{DynamicResource window.desktop.companies.header.taxnumber}" Binding="{Binding Taxnumber}"></DataGridTextColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                    <Label Grid.Row="4" Style="{DynamicResource LineDark}"></Label>
                                                    <Label Grid.Row="5" Style="{DynamicResource LineLight}"></Label>
                                                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                                                        
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </TabItem>
                                        <TabItem Header="Persons" x:Name="pagePersons">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1"></RowDefinition>
                                                    <RowDefinition></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Label Style="{DynamicResource LineLight}"></Label>
                                                <Grid Grid.Row="1">
                                                    
                                                </Grid>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                                <Label Grid.Column="1" Style="{DynamicResource LineDark}"></Label>
                                <Label Grid.Column="2" Style="{DynamicResource LineLight}"></Label>
                            </Grid>
                            <GridSplitter Grid.Column="1"></GridSplitter>
                            <Grid Grid.Column="2" x:Name="grdRight">
                                
                            </Grid>
                        </Grid>
                        <Label Grid.Row="1" Style="{DynamicResource LineDark}"></Label>
                        <Label Grid.Row="2" Style="{DynamicResource LineLight}"></Label>
                    </Grid>
                    <GridSplitter Grid.Row="1"></GridSplitter>
                    <Grid Grid.Row="2" x:Name="grdButtom">
                        
                    </Grid>
                </Grid>
            </Grid>
            <Label Grid.Row="4" Style="{DynamicResource LineDark}"></Label>
            <Label Grid.Row="5" Style="{DynamicResource LineLight}"></Label>
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"  Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Padding="0" Width="16"></Label>
                    <Label x:Name="lblDate" Padding="0" Content="01-01-2026 12:00" FontSize="14" Foreground="{DynamicResource StatusBrush}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="32"></Label>
                    <Label x:Name="lblUserHeader" Padding="0" Content="{DynamicResource window.desktop.status.header.user}" FontSize="14" Foreground="{DynamicResource StatusBrush}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="16"></Label>
                    <Label x:Name="lblUser" Padding="0" FontSize="14" Foreground="{DynamicResource StatusBrushHighlite}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="32"></Label>
                    <Label x:Name="lblCompanyHeader" Padding="0" Content="{DynamicResource window.desktop.status.header.company}" FontSize="14" Foreground="{DynamicResource StatusBrush}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="16"></Label>
                    <Label x:Name="lblCompany" Padding="0" FontSize="14" Foreground="{DynamicResource StatusBrushHighlite}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="32"></Label>
                    <Label x:Name="lblPersonHeader" Padding="0" Content="{DynamicResource window.desktop.status.header.person}" FontSize="14" Foreground="{DynamicResource StatusBrush}" FontFamily="Bahnschrift"></Label>
                    <Label Padding="0" Width="16"></Label>
                    <Label x:Name="lblPerson" Padding="0" FontSize="14" Foreground="{DynamicResource StatusBrushHighlite}" FontFamily="Bahnschrift"></Label>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Label Padding="0" VerticalAlignment="Center" Content="©2000 Emdesoft Developments A/S  " FontSize="14" Foreground="{DynamicResource StatusBrush}" FontFamily="Bahnschrift"></Label>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
    
</Window>
