<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type Label}" x:Key="DarkLine">
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="{DynamicResource PrimaryLineDark}"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LightLine">
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="{DynamicResource PrimaryLineLight}"></Setter>
    </Style>
    <Style TargetType="{x:Type GridSplitter}">
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="Transparent"></Setter>
    </Style>
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="BorderBrush" Value="Transparent"></Setter>
    </Style>
    <Style TargetType="{x:Type Window}" x:Key="DefaultDialogStyle">
        <Setter Property="Background" Value="{DynamicResource PrimaryDialogBackColor}"></Setter>
        <Setter Property="WindowStyle" Value="None"></Setter>
        <Setter Property="AllowsTransparency" Value="False"></Setter>
    </Style>
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="IsEditable" Value="True"></Setter>
        <Setter Property="Padding" Value="4 0 0 0"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}">
        <Setter Property="Padding" Value="0"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LabelHeader">
        <Setter Property="FontSize" Value="10"></Setter>
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"></Setter>
    </Style>
    <Style x:Key="Body_Content_DataGrid_Centering" TargetType="{x:Type DataGridCell}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Grid Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type DataGridRow}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource DatagridHoverColor}" />
                <Setter Property="Height" Value="24" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="HeadersVisibility" Value="Column"></Setter>
        <Setter Property="HorizontalGridLinesBrush" Value="Silver"></Setter>
        <Setter Property="GridLinesVisibility" Value="Horizontal"></Setter>
        <Setter Property="IsReadOnly" Value="True"></Setter>
        <Setter Property="AlternatingRowBackground" Value="#FFDEE8F3"></Setter>
        <Setter Property="AlternationCount" Value="2"></Setter>
        <Setter Property="AutoGenerateColumns" Value="False"></Setter>
        <Setter Property="BorderBrush" Value="Transparent"></Setter>
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="RowHeight" Value="24"></Setter>
    </Style>

</ResourceDictionary>