<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type Label}" x:Key="DarkLine">
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="{DynamicResource PrimaryLineDark}"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LightLine">
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="{DynamicResource PrimaryLineLight}"></Setter>
    </Style>
    <Style TargetType="{x:Type GridSplitter}">
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
        <Setter Property="Background" Value="Transparent"></Setter>
    </Style>
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="BorderBrush" Value="Transparent"></Setter>
    </Style>
    <Style TargetType="{x:Type Window}" x:Key="DefaultDialogStyle">
        <Setter Property="Background" Value="{DynamicResource PrimaryDialogBackColor}"></Setter>
        <Setter Property="WindowStyle" Value="None"></Setter>
        <Setter Property="AllowsTransparency" Value="False"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}">
        <Setter Property="Padding" Value="0"></Setter>
    </Style>
    <Style TargetType="{x:Type Label}" x:Key="LabelHeader">
        <Setter Property="FontSize" Value="10"></Setter>
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"></Setter>
    </Style>

</ResourceDictionary>