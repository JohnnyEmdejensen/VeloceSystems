<Window x:Class="VeloceCRM.Client.Dialogs.PersonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="Person" Height="600" Width="800" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Icon="/Images/keys_48.png">
    <Border BorderBrush="{DynamicResource dialog.bordercolor}" BorderThickness="3" CornerRadius="16" Background="{DynamicResource dialog.background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtTitle" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Text="{DynamicResource company.header.titel}" VerticalAlignment="Center" Style="{DynamicResource dialog.titlebar.text}"></TextBlock>
                <StackPanel x:Name="imgCls" MouseLeftButtonDown="imgCls_MouseLeftButtonDown" Cursor="Hand" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Image Source="/Images/close.png"></Image>
                    <Label Width="8"></Label>
                </StackPanel>
            </Grid>
            <Label Grid.Row="1" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Label Width="8"></Label>
                <Button x:Name="cmdAdd" Click="cmdAdd_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/add_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSave" Click="cmdSave_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_blue_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSaveClose" Click="cmdSaveClose_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_green_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdDelete" Click="cmdDelete_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/delete_16.png" Width="16" Height="16"></Image>
                </Button>
            </StackPanel>
            <Label Grid.Row="3" Background="{DynamicResource dialog.bordercolor}"></Label>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="4"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Column="1" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.firstname}"></Label>
                                <TextBox Grid.Row="1" x:Name="txtFirstname" Text="{Binding Path=Firstname}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.middlename}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Middlename}"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition Width="80"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.surname}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Surname}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.initials}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Initials}"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.street}"></Label>
                                <TextBox Grid.Row="1" Name="txtStreet"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.house}"></Label>
                                <TextBox Grid.Row="1" Name="txtHouse"></TextBox>
                            </Grid>
                            <Grid Grid.Column="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.floor}"></Label>
                                <TextBox Grid.Row="1" Name="txtFloor"></TextBox>
                            </Grid>
                            <Grid Grid.Column="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.door}"></Label>
                                <TextBox Grid.Row="1" Name="txtDoor"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.zipcode}"></Label>
                                <TextBox x:Name="txtZipcode" Grid.Row="1"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.city}"></Label>
                                <TextBox x:Name="txtCity" Grid.Row="1" ></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.country}"></Label>
                            <ComboBox x:Name="cboCountry" Grid.Row="1"></ComboBox>
                        </Grid>
                        <Grid Grid.Row="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.phone}"></Label>
                            <TextBox Grid.Row="1" Text="{Binding Path=Phone}" Width="140" HorizontalAlignment="Left"></TextBox>
                        </Grid>
                        <Grid Grid.Row="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.mobile}"></Label>
                            <TextBox Grid.Row="1" Text="{Binding Path=Mobile}" Width="140" HorizontalAlignment="Left"></TextBox>
                        </Grid>
                        <Grid Grid.Row="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.email}"></Label>
                            <TextBox Grid.Row="1" Text="{Binding Path=Email}"></TextBox>
                        </Grid>
                    </Grid>
                </Grid>
                <GridSplitter Grid.Column="1"></GridSplitter>
                <Grid Grid.Column="2">
                    <TabControl>
                        <TabItem Header="{DynamicResource person.page.header.person}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Background="{StaticResource dialog.bordercolor}"></Label>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition Height="36"></RowDefinition>
                                        <RowDefinition Height="8"></RowDefinition>
                                        <RowDefinition></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="16"></RowDefinition>
                                            <RowDefinition></RowDefinition>
                                        </Grid.RowDefinitions>
                                        <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource person.page.header.company}"></Label>
                                        <ComboBox Grid.Row="1" x:Name="cboCompany" SelectedValue="{Binding Path=CompanyId}"></ComboBox>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
            <Label Grid.Row="5" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="6" Orientation="Horizontal">

            </StackPanel>
        </Grid>
    </Border>
</Window>
