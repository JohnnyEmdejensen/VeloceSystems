<Window x:Class="VeloceCRM.Client.Dialogs.ActivityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="Activity" Height="500" Width="700" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Icon="/Images/keys_48.png">
    <Border BorderBrush="{DynamicResource dialog.bordercolor}" BorderThickness="3" CornerRadius="16" Background="{DynamicResource dialog.background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtTitle" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Text="{DynamicResource activity.header.titel}" VerticalAlignment="Center" Style="{DynamicResource dialog.titlebar.text}"></TextBlock>
                <StackPanel x:Name="imgCls" MouseLeftButtonDown="imgCls_MouseLeftButtonDown" Cursor="Hand" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Image Source="/Images/close.png"></Image>
                    <Label Width="8"></Label>
                </StackPanel>
            </Grid>
            <Label Grid.Row="1" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Label Width="8"></Label>
                <Button x:Name="cmdAdd" Click="cmdAdd_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/add_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSave" Click="cmdSave_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_blue_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSaveClose" Click="cmdSaveClose_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_green_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdDelete" Click="cmdDelete_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/delete_16.png" Width="16" Height="16"></Image>
                </Button>
            </StackPanel>
            <Label Grid.Row="3" Background="{DynamicResource dialog.bordercolor}"></Label>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="4"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Column="1" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.activitytype}"></Label>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="radTask" Grid.Column="0" Content="{DynamicResource activity.header.task}"></RadioButton>
                                <RadioButton x:Name="radPhone" Grid.Column="2" Content="{DynamicResource activity.header.phone}"></RadioButton>
                                <RadioButton x:Name="radMeeting" Grid.Column="4" Content="{DynamicResource activity.header.meeting}"></RadioButton>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.starts}"></Label>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="8"></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtStartsDate" LostFocus="txtStartsDate_LostFocus" Grid.Column="0"></TextBox>
                                    <TextBox x:Name="txtStartsTime" LostFocus="txtStartsTime_LostFocus" Grid.Column="2"></TextBox>
                                </Grid>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.ends}"></Label>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="8"></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtEndsDate" LostFocus="txtEndsDate_LostFocus" Grid.Column="0"></TextBox>
                                    <TextBox x:Name="txtEndsTime" LostFocus="txtEndsTime_LostFocus" Grid.Column="2"></TextBox>
                                </Grid>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.subject}"></Label>
                            <TextBox x:Name="txtSubject" Grid.Row="1" Text="{Binding Path=Subject}"></TextBox>
                        </Grid>
                        <Grid Grid.Row="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label x:Name="lblFollowoupType" MouseLeftButtonDown="lblFollowoupType_MouseLeftButtonDown" Style="{StaticResource HeaderLabelClickAble}" Content="{DynamicResource activity.header.followuptype}"></Label>
                            <ComboBox x:Name="cboFollowuptype" SelectedValue="{Binding Path=FollowuptypeId}" Grid.Row="1"></ComboBox>
                        </Grid>
                        <Grid Grid.Row="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabelClickAble}" Content="{DynamicResource activity.header.company}"></Label>
                            <ComboBox x:Name="cboCompany" Grid.Row="1" SelectedValue="{Binding Path=CompanyId}"></ComboBox>
                        </Grid>
                        <Grid Grid.Row="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabelClickAble}" Content="{DynamicResource activity.header.person}"></Label>
                            <ComboBox x:Name="cboPerson" Grid.Row="1" SelectedValue="{Binding Path=PersonId}"></ComboBox>
                        </Grid>
                        <Grid Grid.Row="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabelClickAble}" Content="{DynamicResource activity.header.salesperson}"></Label>
                            <ComboBox x:Name="cboSalesperson" Grid.Row="1" SelectedValue="{Binding Path=SalespersonId}"></ComboBox>
                        </Grid>
                    </Grid>
                </Grid>
                <GridSplitter Grid.Column="1"></GridSplitter>
                <Grid Grid.Column="2">
                    <TabControl>
                        <TabItem Header="{DynamicResource activity.page.header.reason}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Background="{StaticResource dialog.bordercolor}"></Label>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25"></RowDefinition>
                                        <RowDefinition Height="1"></RowDefinition>
                                        <RowDefinition></RowDefinition>
                                        <RowDefinition Height="1"></RowDefinition>
                                        <RowDefinition Height="25"></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">

                                    </StackPanel>
                                    <Label Grid.Row="1" Background="{StaticResource dialog.bordercolor}"></Label>
                                    <Grid Grid.Row="2">
                                        <RichTextBox Grid.Row="0">
                                            <FlowDocument>
                                                <Paragraph>
                                                    <Run Text="{Binding Path=Reason}" FontFamily="Comic Sans MS" FontSize="14"></Run>
                                                </Paragraph>
                                            </FlowDocument>
                                        </RichTextBox>
                                    </Grid>
                                    <Label Grid.Row="3" Background="{StaticResource dialog.bordercolor}"></Label>
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{DynamicResource activity.page.header.conclution}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Background="{StaticResource dialog.bordercolor}"></Label>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25"></RowDefinition>
                                        <RowDefinition Height="1"></RowDefinition>
                                        <RowDefinition></RowDefinition>
                                        <RowDefinition Height="1"></RowDefinition>
                                        <RowDefinition Height="25"></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">

                                    </StackPanel>
                                    <Label Grid.Row="1" Background="{StaticResource dialog.bordercolor}"></Label>
                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition></RowDefinition>
                                            <RowDefinition Height="1"></RowDefinition>
                                            <RowDefinition Height="100"></RowDefinition>
                                        </Grid.RowDefinitions>
                                        <RichTextBox Grid.Row="0">
                                            <FlowDocument>
                                                <Paragraph>
                                                    <Run Text="{Binding Path=Reason}"></Run>
                                                </Paragraph>
                                            </FlowDocument>
                                        </RichTextBox>
                                        <Label Grid.Row="1" Background="{StaticResource dialog.bordercolor}"></Label>
                                        <Grid Grid.Row="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="8"></RowDefinition>
                                                <RowDefinition Height="36"></RowDefinition>
                                                <RowDefinition Height="8"></RowDefinition>
                                                <RowDefinition Height="36"></RowDefinition>
                                                <RowDefinition></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition></ColumnDefinition>
                                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                                    <ColumnDefinition></ColumnDefinition>
                                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="16"></RowDefinition>
                                                        <RowDefinition></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.took}"></Label>
                                                    <TextBox Grid.Row="1" Text="{Binding Path=TookMinutes}"></TextBox>
                                                </Grid>
                                                <Grid Grid.Column="2">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="16"></RowDefinition>
                                                        <RowDefinition></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.billed}"></Label>
                                                    <TextBox Grid.Row="1" Text="{Binding Path=BilledMinutes}"></TextBox>
                                                </Grid>
                                            </Grid>
                                            <Grid Grid.Row="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition></ColumnDefinition>
                                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                                    <ColumnDefinition></ColumnDefinition>
                                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="16"></RowDefinition>
                                                        <RowDefinition></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource activity.header.completed}"></Label>
                                                    <CheckBox Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"></CheckBox>
                                                </Grid>
                                                <Grid Grid.Column="2">

                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                    <Label Grid.Row="3" Background="{StaticResource dialog.bordercolor}"></Label>
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">

                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
            <Label Grid.Row="5" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="6" Orientation="Horizontal">

            </StackPanel>
        </Grid>
    </Border>
</Window>
