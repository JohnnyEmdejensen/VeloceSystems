<Window x:Class="VeloceCRM.Client.Dialogs.CompanyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="Company" Height="600" Width="800" ResizeMode="NoResize" Icon="/Images/factory_48.png" Style="{DynamicResource DefaultDialogStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="32"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="8"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtTitle" Padding="8" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Grid.Column="0" VerticalAlignment="Center" Text="Veloce CRM - Company" FontWeight="Bold" Foreground="white"></TextBlock>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="cmdClose" Click="cmdClose_Click" Height="20" Width="20" Background="Transparent">
                    <Image Source="/Images/exit_16.png" Height="16" Width="16"></Image>
                </Button>
                <Label Width="8"></Label>
            </StackPanel>
        </Grid>
        <Label Grid.Row="1" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="2" Style="{DynamicResource LightLine}"></Label>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Label Width="8"></Label>
            <Button x:Name="cmdAdd" Click="cmdAdd_Click" Width="28" Height="28" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.add}" IsEnabled="False">
                <Image Width="24" Height="24" Source="/Images/add_24.png"></Image>
            </Button>
            <Label Width="8"></Label>
            <Button x:Name="cmdSave" Click="cmdSave_Click" Width="28" Height="28" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.save}" IsEnabled="False">
                <Image Width="24" Height="24" Source="/Images/disk_blue_24.png"></Image>
            </Button>
            <Label Width="8"></Label>
            <Button x:Name="cmdSaveClose" Click="cmdSaveClose_Click" Width="28" Height="28" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.saveclose}" IsEnabled="False">
                <Image Width="24" Height="24" Source="/Images/disk_green_24.png"></Image>
            </Button>
            <Label Width="8"></Label>
            <Button x:Name="cmdDelete" Click="cmdDelete_Click" Width="28" Height="28" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.delete}" IsEnabled="False">
                <Image Width="24" Height="24" Source="/Images/delete_24.png"></Image>
            </Button>
        </StackPanel>
        <Label Grid.Row="4" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="5" Style="{DynamicResource LightLine}"></Label>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="4"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="8"></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="8"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Column="1" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="8"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Grid.Row="0" Style="{DynamicResource LabelHeader}" Content="{DynamicResource company.header.number}"></Label>
                        <TextBox Grid.Column="0" Grid.Row="1" Text="{Binding Path=Number}"></TextBox>
                        <Label Grid.Column="2" Grid.Row="0" Style="{DynamicResource LabelHeader}" Content="{DynamicResource company.header.taxnumber}"></Label>
                        <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding Path=Taxnumber}"></TextBox>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="{DynamicResource company.header.name}" Style="{DynamicResource LabelHeader}"></Label>
                        <TextBox Grid.Row="1" Text="{Binding Path=Name}"></TextBox>
                    </Grid>
                </Grid>
            </Grid>
            <GridSplitter Grid.Column="1"></GridSplitter>
            <TabControl Grid.Column="2">
                <TabItem Header="{DynamicResource company.tab.header.company}"></TabItem>
            </TabControl>
        </Grid>
        <Label Grid.Row="7" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="8" Style="{DynamicResource LightLine}"></Label>
        <StackPanel Grid.Row="9" Orientation="Horizontal" VerticalAlignment="Center" >

        </StackPanel>
    </Grid>
</Window>
