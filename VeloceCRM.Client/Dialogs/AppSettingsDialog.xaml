<Window x:Class="VeloceCRM.Client.Dialogs.AppSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="AppSettings" Height="400" Width="600" Icon="/Images/gears_48.png" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border BorderBrush="{DynamicResource dialog.bordercolor}" BorderThickness="3" CornerRadius="16" Background="{DynamicResource dialog.background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="39"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtTitle" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Text="{DynamicResource appsettings.header.title}" VerticalAlignment="Center" Style="{DynamicResource dialog.titlebar.text}"></TextBlock>
                <StackPanel x:Name="imgCls" MouseLeftButtonDown="imgCls_MouseLeftButtonDown" Cursor="Hand" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Image Source="/Images/close.png"></Image>
                    <Label Width="8"></Label>
                </StackPanel>
            </Grid>
            <Label Grid.Row="1" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                
            </StackPanel>
            <Label Grid.Row="3" Background="{DynamicResource dialog.bordercolor}"></Label>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="4"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="4"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource appsettings.header.private.documentfolder}"></Label>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition Width="24"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtPrivateFolder" Grid.Column="0" Text="{Binding Path=PrivateDocumentFolder}"></TextBox>
                                <Button Grid.Column="2" x:Name="dirPrivate" Click="dirPrivate_Click">
                                    <Image Source="/Images/folder_16.png"></Image>
                                </Button>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource appsettings.header.public.documentfolder}"></Label>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition Width="24"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtPublicFolder" Grid.Column="0" Text="{Binding Path=PublicDocumentFolder}"></TextBox>
                                <Button Grid.Column="2" x:Name="dirPublic" Click="dirPublic_Click">
                                    <Image Source="/Images/folder_16.png"></Image>
                                </Button>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource appsettings.header.send.appointrquest}"></Label>
                            <Grid Grid.Row="1" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="8"></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="chkTask" Checked="chkTask_Checked" Unchecked="chkTask_Unchecked" Grid.Column="0" IsChecked="{Binding Path=SendAppointmentRequestOnTasks}" Content="{DynamicResource appsettings.header.task}"></CheckBox>
                                <CheckBox x:Name="chkPhone" Checked="chkPhone_Checked" Unchecked="chkPhone_Unchecked" Grid.Column="2" IsChecked="{Binding Path=SendAppointmentRequestOnPhone}" Content="{DynamicResource appsettings.header.phone}"></CheckBox>
                                <CheckBox x:Name="chkMeeting" Checked="chkMeeting_Checked" Unchecked="chkMeeting_Unchecked" Grid.Column="4" IsChecked="{Binding Path=SendAppointmentRequestOnMeeting}" Content="{DynamicResource appsettings.header.meeting}"></CheckBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <GridSplitter Grid.Column="1"></GridSplitter>
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                    </Grid>
                </Grid>
            </Grid>
            <Label Grid.Row="5" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" x:Name="btnOK" Click="btnOK_Click" Style="{StaticResource DialogButtonAccept}"></Button>
                <Label Width="8"></Label>
                <Button Content="Cancel" x:Name="btnCancel" Click="btnCancel_Click" Style="{StaticResource DialogButtonDecline}"></Button>
                <Label Width="8"></Label>
            </StackPanel>
        </Grid>
    </Border>
</Window>
