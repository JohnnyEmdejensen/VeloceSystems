<Window x:Class="VeloceCRM.Client.Dialogs.LocationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="Locations" Height="400" Width="800" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Icon="/Images/earth_location_48.png">
    <Border BorderThickness="3" CornerRadius="16" BorderBrush="{DynamicResource dialog.bordercolor}" Background="{DynamicResource dialog.background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="1"></RowDefinition>
                <RowDefinition Height="25"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtTitle" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Grid.Column="0" Style="{DynamicResource dialog.titlebar.text}" Text="{DynamicResource locations.header.titel}" VerticalAlignment="Center"></TextBlock>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Image Source="/Images/close.png" x:Name="imgCls" MouseLeftButtonDown="imgCls_MouseLeftButtonDown" Cursor="Hand"></Image>
                    <Label Width="8"></Label>
                </StackPanel>
            </Grid>
            <Label Grid.Row="1" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Label Width="8"></Label>
                <Button x:Name="cmdAdd" Click="cmdAdd_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/add_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSave" Click="cmdSave_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_blue_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdSaveClose" Click="cmdSaveClose_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/disk_green_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdDelete" Click="cmdDelete_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/delete_16.png" Width="16" Height="16"></Image>
                </Button>
                <Label Width="8"></Label>
                <Button x:Name="cmdCheck" Click="cmdCheck_Click" Width="24" Height="24" Style="{StaticResource ToolbarButton}" IsEnabled="False">
                    <Image Source="/Images/check_16.png" Width="16" Height="16"></Image>
                </Button>
            </StackPanel>
            <Label Grid.Row="3" Background="{DynamicResource dialog.bordercolor}"></Label>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"></ColumnDefinition>
                    <ColumnDefinition Width="4"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="8"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="8"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="8"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition Height="36"></RowDefinition>
                            <RowDefinition Height="8"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition Width="56"></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.street}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Street}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.house}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=House}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.floor}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Floor}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.door}"></Label>
                                <TextBox Grid.Row="1" Text="{Binding Path=Door}"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.zipcode}"></Label>
                                <TextBox Grid.Row="1" x:Name="txtZipcode"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.city}"></Label>
                                <TextBox Grid.Row="1" x:Name="txtCity"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.country}"></Label>
                            <ComboBox Grid.Row="1" x:Name="cboCountry"></ComboBox>
                        </Grid>
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.latitude}"></Label>
                                <TextBox Grid.Row="1" x:Name="txtLatitude"></TextBox>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.longitude}"></Label>
                                <TextBox Grid.Row="1" x:Name="txtLongitude"></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition Width="8"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Label Style="{StaticResource HeaderLabel}" Content="{DynamicResource locations.header.verified}"></Label>
                                <CheckBox Grid.Row="1" x:Name="chkVerified" HorizontalAlignment="Center"></CheckBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <GridSplitter Grid.Column="1"></GridSplitter>
                <Grid Grid.Column="2">
                    <TabControl>
                        <TabItem Header="{DynamicResource locations.header.titel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="25"></RowDefinition>
                                    <RowDefinition Height="1"></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition Height="1"></RowDefinition>
                                    <RowDefinition Height="25"></RowDefinition>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    
                                </StackPanel>
                                <Label Grid.Row="1" Background="{DynamicResource dialog.bordercolor}"></Label>
                                <DataGrid Grid.Row="2" x:Name="dgLocations" SelectionChanged="dgLocations_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Visibility="Collapsed"></DataGridTextColumn>
                                        <DataGridTextColumn Header="{DynamicResource locations.column.header.street}" Binding="{Binding Street}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="40" Header="{DynamicResource locations.column.header.house}" Binding="{Binding House}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="24" Header="{DynamicResource locations.column.header.floor}" Binding="{Binding Floor}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="24" Header="{DynamicResource locations.column.header.door}" Binding="{Binding Door}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="54" Header="{DynamicResource locations.column.header.zipcode}" Binding="{Binding Zipcode}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="100" Header="{DynamicResource locations.column.header.city}" Binding="{Binding City}"></DataGridTextColumn>
                                        <DataGridTextColumn Width="100" Header="{DynamicResource locations.column.header.country}" Binding="{Binding Country}"></DataGridTextColumn>
                                        <DataGridCheckBoxColumn Width="16" Header="{DynamicResource locations.column.header.verified}" Binding="{Binding IsVerified}"></DataGridCheckBoxColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Label Grid.Row="3" Background="{DynamicResource dialog.bordercolor}"></Label>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
            <Label Grid.Row="5" Background="{DynamicResource dialog.bordercolor}"></Label>
            <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
                
            </StackPanel>
        </Grid>
    </Border>
</Window>
