<Window x:Class="VeloceCRM.Client.Dialogs.LocationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeloceCRM.Client.Dialogs"
        mc:Ignorable="d"
        Tag="Location" Height="300" Width="600" ResizeMode="NoResize" Icon="/Images/earth_location_48.png" Style="{DynamicResource DefaultDialogStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="1"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="8"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtTitle" Padding="8" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown" Grid.Column="0" VerticalAlignment="Center" Text="Veloce CRM - Postalzone" FontWeight="Bold" Foreground="white"></TextBlock>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="cmdClose" Click="cmdClose_Click" Height="20" Width="20" Background="Transparent">
                    <Image Source="/Images/exit_16.png" Height="16" Width="16"></Image>
                </Button>
                <Label Width="8"></Label>
            </StackPanel>
        </Grid>
        <Label Grid.Row="1" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="2" Style="{DynamicResource LightLine}"></Label>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Label Width="4"></Label>
            <Button x:Name="cmdAdd" Click="cmdAdd_Click" Width="20" Height="20" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.add}" IsEnabled="False">
                <Image Width="16" Height="16" Source="/Images/add_16.png"></Image>
            </Button>
            <Label Width="4"></Label>
            <Button x:Name="cmdSave" Click="cmdSave_Click" Width="20" Height="20" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.save}" IsEnabled="False">
                <Image Width="16" Height="16" Source="/Images/disk_blue_16.png"></Image>
            </Button>
            <Label Width="4"></Label>
            <Button x:Name="cmdSaveClose" Click="cmdSaveClose_Click" Width="20" Height="20" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.saveclose}" IsEnabled="False">
                <Image Width="16" Height="16" Source="/Images/disk_green_16.png"></Image>
            </Button>
            <Label Width="4"></Label>
            <Button x:Name="cmdDelete" Click="cmdDelete_Click" Width="20" Height="20" Background="Transparent" ToolTip="{DynamicResource country.button.tooltip.delete}" IsEnabled="False">
                <Image Width="16" Height="16" Source="/Images/delete_16.png"></Image>
            </Button>
        </StackPanel>
        <Label Grid.Row="4" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="5" Style="{DynamicResource LightLine}"></Label>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"></ColumnDefinition>
                <ColumnDefinition Width="4"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="8"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition Height="32"></RowDefinition>
                        <RowDefinition Height="4"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource LabelHeader}" Content="{DynamicResource location.header.street}"></Label>
                        <TextBox x:Name="txtName" Grid.Row="1" Text="{Binding Path=Street}" MaxLength="128"></TextBox>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource LabelHeader}" Content="{DynamicResource location.header.house}"></Label>
                        <TextBox Grid.Row="1" Text="{Binding Path=House}" MaxLength="16" Width="64" HorizontalAlignment="Left" ></TextBox>
                    </Grid>
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource LabelHeader}" Content="{DynamicResource location.header.floor}"></Label>
                        <TextBox Grid.Row="1" Text="{Binding Path=Floor}" MaxLength="16" Width="64" HorizontalAlignment="Left" ></TextBox>
                    </Grid>
                    <Grid Grid.Row="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource LabelHeader}" Content="{DynamicResource location.header.door}"></Label>
                        <TextBox Grid.Row="1" Text="{Binding Path=Door}" MaxLength="16" Width="64" HorizontalAlignment="Left" ></TextBox>
                    </Grid>
                    <Grid Grid.Row="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="12"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource LabelHeader}" Content="{DynamicResource location.header.postalzone}"></Label>
                        <ComboBox Grid.Row="1" x:Name="cboPostalzones" SelectedValue="{Binding Path=PostalzoneId}"></ComboBox>
                    </Grid>
                </Grid>
            </Grid>
            <GridSplitter Grid.Column="1"></GridSplitter>
            <DataGrid Grid.Column="2" x:Name="dgLocation" SelectionChanged="dgLocation_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Visibility="Collapsed"></DataGridTextColumn>
                    <DataGridTextColumn Header="Street"  Binding="{Binding Street}"></DataGridTextColumn>
                    <DataGridTextColumn Header="House" Width="48" Binding="{Binding House}"></DataGridTextColumn>
                    <DataGridTextColumn Header="Floor" Width="32" Binding="{Binding Floor}"></DataGridTextColumn>
                    <DataGridTextColumn Header="Door" Width="32" Binding="{Binding Door}"></DataGridTextColumn>
                    <DataGridTextColumn Header="Zone" Width="140" Binding="{Binding Postzone}"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <Label Grid.Row="7" Style="{DynamicResource DarkLine}"></Label>
        <Label Grid.Row="8" Style="{DynamicResource LightLine}"></Label>
        <StackPanel Grid.Row="9" Orientation="Horizontal" VerticalAlignment="Center" >

        </StackPanel>
    </Grid>
</Window>
